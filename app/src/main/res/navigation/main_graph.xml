<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_graph"
    app:startDestination="@id/splashFragment">
    <fragment
        android:id="@+id/splashFragment"
        android:name="voloshyn.android.redrive.presentation.splash.SplashFragment"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_tabsFragment"
            app:destination="@id/tabsFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_splashFragment_to_onBoardFragmentContainer"
            app:destination="@id/onBoardFragmentContainer"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/onBoardFragmentContainer"
        android:name="voloshyn.android.redrive.presentation.onBoard.OnBoardFragmentContainer"
        tools:layout="@layout/fragment_on_board" >
        <action
            android:id="@+id/action_onBoardFragmentContainer_to_tabsFragment"
            app:destination="@id/tabsFragment"
            app:popUpTo="@id/onBoardFragmentContainer"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/tabsFragment"
        android:name="voloshyn.android.redrive.presentation.tabs.TabsFragment"
        tools:layout="@layout/fragment_tabs">
        <action
            android:id="@+id/action_tabsFragment_to_signInFragment"
            app:destination="@id/signInFragment" />
        <action
            android:id="@+id/action_tabsFragment_to_newRefuelFragment"
            app:destination="@id/newRefuelFragment" />
    </fragment>
    <fragment
        android:id="@+id/signInFragment"
        android:name="voloshyn.android.redrive.presentation.auth.SignInFragment"
        android:label="Sign In"
        tools:layout="@layout/fragment_sign_in">
        <action
            android:id="@+id/action_signInFragment_to_signUpFragment"
            app:destination="@id/signUpFragment" />
    </fragment>
    <fragment
        android:id="@+id/signUpFragment"
        android:name="voloshyn.android.redrive.presentation.auth.SignUpFragment"
        android:label="Sign Up"
        tools:layout="@layout/fragment_sign_up"/>
    <fragment
        android:id="@+id/newRefuelFragment"
        android:name="voloshyn.android.redrive.presentation.tabs.newRefuel.NewRefuelFragment"
        android:label="New refuel"
        tools:layout="@layout/fragment_new_refuel"/>
</navigation>