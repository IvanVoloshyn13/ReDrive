<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <!--OS -> OnBoard and SignIn_SignUp -->
    <style name="OS.MaterialButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/os_primary_container_color</item>
        <item name="android:textColor">@color/os_on_primary_container_color</item>
    </style>

    <style name="TextAppearance.OS.Medium" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/os_text_color</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">18sp</item>

    </style>

    <style name="TextAppearance.OS.Default" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/os_text_color</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">14sp</item>

    </style>

    <style name="TextInputLayout.OS" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_marginStart">24dp</item>
        <item name="android:layout_marginEnd">24dp</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="cursorColor">@color/black</item>
        <item name="hintTextColor">#D7D6D6</item>
        <item name="boxStrokeColor">#D7D6D6</item>
        <item name="helperText">Required</item>
        <item name="helperTextEnabled">true</item>
        <item name="helperTextTextColor">@color/md_theme_error</item>


    </style>

    <!--OS -> OnBoard and SignIn_SignUp -->


    <style name="TextAppearance.ReDrive.Cards" parent="TextAppearance.AppCompat">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textSize">20sp</item>

    </style>

    <style name="TextAppearance.ReDrive.Cards.Small" parent="TextAppearance.AppCompat">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="fontFamily">@font/inter_light</item>
        <item name="android:textSize">12sp</item>

    </style>

    <style name="TextAppearance.ReDrive.Cards.Medium" parent="TextAppearance.AppCompat">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:textSize">16sp</item>

    </style>

    <style name="TextAppearance.ReDrive.Cards.Regular" parent="TextAppearance.AppCompat">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textSize">16sp</item>

    </style>


    <style name="BaseTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_marginStart">24dp</item>
        <item name="android:layout_marginEnd">24dp</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="cursorColor">@color/black</item>
        <item name="hintTextColor">#D7D6D6</item>
        <item name="boxStrokeColor">#D7D6D6</item>
        <item name="helperText">Required</item>
        <item name="helperTextEnabled">true</item>
        <item name="helperTextTextColor">#00B8D4</item>


    </style>

    <style name="TextInputLayout.Refuel" parent="Widget.MaterialComponents.TextInputLayout.FilledBox.Dense">
        <item name="android:layout_marginStart">@dimen/small_margin</item>
        <item name="android:layout_marginEnd">@dimen/small_margin</item>
        <item name="boxBackgroundColor">#00FFFFFF</item>
        <item name="cursorColor">@color/black</item>
        <item name="hintTextColor">?attr/colorOnSurface</item>
        <item name="boxStrokeColor">?attr/colorOnSurface</item>
        <item name="helperText">Required</item>
        <item name="helperTextEnabled">true</item>
        <item name="helperTextTextColor">@color/md_theme_error</item>


    </style>

    <style name="App.ThemeOverlay.DatePicker" parent="@style/ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorSurfaceContainerHigh">@color/md_theme_light_surface</item>
        <item name="colorOnSurfaceVariant">@color/black</item>
        <item name="materialCalendarStyle">@style/App.MaterialCalendarStyle.Default</item>
        <item name="materialCalendarHeaderDivider">@style/App.MaterialCalendar.MaterialCalendar.HeaderDivider</item>
        <item name="buttonBarNegativeButtonStyle">@style/App.ButtonBarNegativeButtonStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/App.ButtonBarPositiveButtonStyle</item>

    </style>

    <style name="App.MaterialCalendarStyle.Default" parent="Widget.Material3.MaterialCalendar">
        <item name="daySelectedStyle">@style/App.MaterialCalendar.DaySelectedStyle</item>
        <item name="dayTodayStyle">@style/App.MaterialCalendar.DayTodayStyle</item>


    </style>

    <style name="App.MaterialCalendar.DaySelectedStyle" parent="Widget.Material3.MaterialCalendar.Day.Selected">
        <item name="itemFillColor">@color/md_theme_tertiary</item>
        <item name="itemTextColor">@color/md_theme_light_primary</item>
    </style>


    <style name="App.MaterialCalendar.DayTodayStyle" parent="Widget.Material3.MaterialCalendar.Day.Today">
        <item name="itemTextColor">@color/md_theme_tertiary</item>
        <item name="itemStrokeColor">@color/md_theme_tertiary</item>
        <item name="itemStrokeWidth">2dp</item>

    </style>

    <style name="App.MaterialCalendar.MaterialCalendar.HeaderDivider" parent="Widget.Material3.MaterialCalendar.HeaderDivider">
        <item name="android:visibility">visible</item>
    </style>

    <style name="App.ButtonBarNegativeButtonStyle" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/md_theme_light_onSurfaceVariant</item>

    </style>
    <style name="App.ButtonBarPositiveButtonStyle" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/md_theme_tertiary</item>

    </style>

    <style name="App.VehicleToggle"  parent="ThemeOverlay.Material3.Button" >
        <item name="colorSecondaryContainer">@color/md_theme_tertiary</item>
    </style>

    <style name="App.VehicleButton" parent="Widget.Material3.Button.IconButton.Filled">
        <item name="iconGravity">textStart</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">0dp</item>
        <item name="iconSize">32dp</item>
        <item name="iconTint">@color/md_theme_light_primary</item>

    </style>

    <style name="App.ActivityToolbar" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="navigationIconTint">@color/black</item>

    </style>








</resources>